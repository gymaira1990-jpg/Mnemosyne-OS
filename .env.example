# Mnemosyne OS 环境配置
# 复制此文件为 .env 并填入你的密钥

# ── 必填: 火山引擎 ARK API (豆包模型) ──
# 在 https://console.volcengine.com/ark 获取
ARK_API_KEY=ark-your-key-here

# ── 可选: 其他模型后端 ──
# OpenAI 兼容 (用于替代豆包)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek (用于 Tier 4 审计)
# DEEPSEEK_API_KEY=sk-...

# ── Embedding 配置 ──
# 维度: 1024 或 2048 (需与 pgvector 索引一致)
EMBED_DIM=1024

# ── PostgreSQL ──
PGUSER=postgres
PGPASSWORD=
PGDATABASE=mnemosyne
PGHOST=127.0.0.1
PGPORT=5432

# ── 服务 ──
MNEMOSYNE_HOST=127.0.0.1
MNEMOSYNE_PORT=8010
