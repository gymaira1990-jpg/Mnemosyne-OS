# Mnemosyne OS 环境配置模板
# 复制为 .env 并填入你的密钥

# ── 模型后端 (至少配一个) ──

# 推荐: 火山引擎 ARK (豆包) — 便宜、中文好、支持JSON mode
# 注册: https://console.volcengine.com/ark
ARK_API_KEY=***

# 备选: OpenAI 兼容 API (OpenAI / DeepSeek / 本地 vLLM)
# OPENAI_API_KEY=***
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_CHAT_MINI=gpt-4o-mini

# 切换后端: ark (默认) 或 openai
# MODEL_BACKEND=ark

# ── PostgreSQL ──
PGUSER=postgres
PGPASSWORD=your-db-password-here
PGDATABASE=mnemosyne
PGHOST=127.0.0.1
PGPORT=5432

# ── 服务 ──
MNEMOSYNE_HOST=127.0.0.1
MNEMOSYNE_PORT=8010
